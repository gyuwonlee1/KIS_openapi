KIS_APP_KEY=
KIS_APP_SECRET=
DISCORD_WEBHOOK_URL=

# KIS production REST endpoint.
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# Serverless runtime options.
PORTFOLIO_PATH=portfolio.json
STATE_PATH=.cache/kis-alerts/last_alerts.json
KIS_TOKEN_CACHE_PATH=.cache/kis-alerts/kis_token.json
MARKET_HOURS_ENABLED=true

# KIS rate-limit guardrails.
KIS_MIN_INTERVAL_SECONDS=0.2
KIS_OVERSEAS_INTERVAL_SECONDS=1.0
HTTP_TIMEOUT_SECONDS=10

# Web editor deployment settings.
ADMIN_PASSWORD=
GITHUB_TOKEN=
GITHUB_REPO=gyuwonlee1/KIS_openapi
GITHUB_BRANCH=main

# Discord natural-language setup.
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
